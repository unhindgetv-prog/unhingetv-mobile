{
  "expo": {
    "name": "UnhingeTV",
    "slug": "unhingetv",
    "owner": "unhingetv",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "scheme": "unhingetv",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.unhingetv.app",
      "backgroundColor": "#000000"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.unhingetv.app",
      "versionCode": 1,
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://unhingetv.vercel.app",
      "muxEnvKey": "9og1ccmli19nha7mho0hklmb9",
      "router": {},
      "eas": {
        "projectId": "1fa82ba8-75b5-4d87-a213-bcd8e12c431b"
      }
    }
  }
}
